// ═══════════════════════════════════════════════════════════════
// SIVRCE 3D MAP SYSTEM — Award Winning Building Intelligence
// 2026 Standards: CesiumJS + Google Photorealistic 3D Tiles
// ═══════════════════════════════════════════════════════════════

enum Building3DStatus {
  active
  under_construction
  planned
  demolished
  renovation

  @@map("building_3d_status")
}

enum BuildingMaterial {
  concrete
  brick
  glass_steel
  wood
  mixed
  panel
  stone
  other

  @@map("building_material")
}

/// Extended 3D building data for CesiumJS visualization
model Building3D {
  id                String           @id @default(uuid()) @db.Uuid
  mapBuildingId     String           @unique @map("map_building_id") @db.Uuid
  
  // 3D Geometry
  footprintGeoJson  Json             @map("footprint_geojson")
  heightMeters      Float            @map("height_meters")
  floorCount        Int              @map("floor_count")
  floorHeight       Float            @default(3.0) @map("floor_height")
  undergroundFloors Int              @default(0) @map("underground_floors")
  
  // 3D Model
  modelUrl3D        String?          @map("model_url_3d") @db.Text
  modelFormat       String?          @map("model_format") @db.VarChar(20)
  
  // Visual Properties
  material          BuildingMaterial @default(concrete)
  yearBuilt         Int?             @map("year_built")
  yearRenovated     Int?             @map("year_renovated")
  architect         String?          @db.VarChar(200)
  developerId       String?          @map("developer_id") @db.VarChar(120)
  
  // Status
  status            Building3DStatus @default(active)
  constructionProgress Float?        @map("construction_progress")
  readyBy           DateTime?        @map("ready_by") @db.Timestamptz(6)
  
  // Metadata
  parkingSpaces     Int?             @map("parking_spaces")
  elevatorCount     Int?             @map("elevator_count")
  hasUndergroundParking Boolean      @default(false) @map("has_underground_parking")
  hasRooftopAccess  Boolean          @default(false) @map("has_rooftop_access")
  
  // Cesium Position
  cesiumPosition    Json?            @map("cesium_position")
  boundingBox       Json?            @map("bounding_box")
  
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedById       String?          @map("updated_by_id") @db.VarChar(120)
  
  mapBuilding       MapBuilding      @relation(fields: [mapBuildingId], references: [id], onDelete: Cascade)
  floors            BuildingFloor[]
  listingLocations  ListingLocation[]
  developer         DeveloperProfile?       @relation(fields: [developerId], references: [id], onDelete: SetNull)
  updatedBy         User?            @relation("Building3DUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  
  @@index([status, yearBuilt], map: "building_3d_status_year_idx")
  @@index([developerId], map: "building_3d_developer_idx")
  @@index([readyBy], map: "building_3d_ready_idx")
  @@map("buildings_3d")
}

/// Individual floor data within a 3D building
model BuildingFloor {
  id              String    @id @default(uuid()) @db.Uuid
  building3DId    String    @map("building_3d_id") @db.Uuid
  floorNumber     Int       @map("floor_number")
  displayLabel    String?   @map("display_label") @db.VarChar(20)
  
  // Floor geometry
  footprintGeoJson Json?    @map("footprint_geojson")
  areaSqm         Float?    @map("area_sqm")
  heightMeters    Float     @default(3.0) @map("height_meters")
  
  // Floor properties
  totalUnits      Int       @default(0) @map("total_units")
  availableUnits  Int       @default(0) @map("available_units")
  
  // Deal type breakdown
  forSaleCount     Int      @default(0) @map("for_sale_count")
  forRentCount     Int      @default(0) @map("for_rent_count")
  forDailyCount    Int      @default(0) @map("for_daily_count")
  forPledgeCount   Int      @default(0) @map("for_pledge_count")
  
  // Pricing analytics
  pricePerSqmMin  Float?    @map("price_per_sqm_min")
  pricePerSqmMax  Float?    @map("price_per_sqm_max")
  pricePerSqmAvg  Float?    @map("price_per_sqm_avg")
  
  // Visual
  color           String?   @db.VarChar(7)
  opacity         Float     @default(1.0)
  isHighlighted   Boolean   @default(false) @map("is_highlighted")
  
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  
  building3D      Building3D @relation(fields: [building3DId], references: [id], onDelete: Cascade)
  listingLocations ListingLocation[]
  
  @@unique([building3DId, floorNumber], map: "building_floor_unique_idx")
  @@index([building3DId, floorNumber], map: "building_floor_building_num_idx")
  @@map("building_floors")
}

/// Precise 3D location of a listing within a building
model ListingLocation {
  id            String    @id @default(uuid()) @db.Uuid
  listingId     String    @unique @map("listing_id") @db.VarChar(120)
  
  // Building association
  building3DId  String?   @map("building_3d_id") @db.Uuid
  buildingFloorId String? @map("building_floor_id") @db.Uuid
  floorNumber   Int?      @map("floor_number")
  
  // 3D Coordinates (lat, lng, altitude)
  latitude      Float
  longitude     Float
  altitude      Float     @default(0)
  
  // Position within floor (normalized 0-1)
  posX          Float?    @map("pos_x")
  posY          Float?    @map("pos_y")
  
  // Cesium entity position
  cesiumCartesian Json?   @map("cesium_cartesian")
  
  // Visual marker
  markerColor   String?   @map("marker_color") @db.VarChar(7)
  markerSize    Float     @default(1.0) @map("marker_size")
  
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  
  building3D    Building3D?  @relation(fields: [building3DId], references: [id], onDelete: SetNull)
  buildingFloor BuildingFloor? @relation(fields: [buildingFloorId], references: [id], onDelete: SetNull)
  listing       Listing      @relation(fields: [listingId], references: [id], onDelete: Cascade)
  
  @@index([building3DId, floorNumber], map: "listing_loc_building_floor_idx")
  @@index([latitude, longitude], map: "listing_loc_lat_lng_idx")
  @@map("listing_locations")
}


/// Editorial blog posts for marketing and SEO content.
model BlogPost {
  id        String   @id @default(cuid()) @db.VarChar(120)
  slug      String   @unique @db.VarChar(240)
  status    BlogPostStatus @default(draft)
  locale    String   @default("ka") @db.VarChar(8)
  category  String?  @db.VarChar(80)
  tags      String[] @default([])
  featuredImage String? @map("featured_image") @db.Text
  authorId  String?  @map("author_id") @db.VarChar(120)
  publishedAt DateTime? @map("published_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  viewCount Int      @default(0) @map("view_count")

  titleKa String @map("title_ka") @db.VarChar(300)
  titleEn String? @map("title_en") @db.VarChar(300)
  titleRu String? @map("title_ru") @db.VarChar(300)

  excerptKa String? @map("excerpt_ka") @db.Text
  excerptEn String? @map("excerpt_en") @db.Text
  excerptRu String? @map("excerpt_ru") @db.Text

  bodyKa String @map("body_ka") @db.Text
  bodyEn String? @map("body_en") @db.Text
  bodyRu String? @map("body_ru") @db.Text

  metaTitleKa String? @map("meta_title_ka") @db.VarChar(300)
  metaTitleEn String? @map("meta_title_en") @db.VarChar(300)
  metaTitleRu String? @map("meta_title_ru") @db.VarChar(300)

  metaDescriptionKa String? @map("meta_description_ka") @db.VarChar(500)
  metaDescriptionEn String? @map("meta_description_en") @db.VarChar(500)
  metaDescriptionRu String? @map("meta_description_ru") @db.VarChar(500)

  author User? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([status, locale], map: "blog_posts_status_locale_idx")
  @@index([slug], map: "blog_posts_slug_idx")
  @@index([publishedAt], map: "blog_posts_published_at_idx")
  @@index([category], map: "blog_posts_category_idx")
  @@map("blog_posts")
}

enum BlogPostStatus {
  draft
  published
  archived

  @@map("blog_post_status")
}

