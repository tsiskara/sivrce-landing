  userId       String    @map("user_id") @db.VarChar(120)
  name         String    @db.VarChar(160)
  params       Json      @default("{}")
  alertEnabled Boolean   @default(true) @map("alert_enabled")
  lastAlertAt  DateTime? @map("last_alert_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@index([userId], map: "saved_searches_user_id_idx")
  @@map("saved_searches")
}

model SavedSearchAlertLog {
  id            String   @id @default(cuid()) @db.VarChar(120)
  savedSearchId String   @map("saved_search_id") @db.VarChar(120)
  listingId     String   @map("listing_id") @db.VarChar(120)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([savedSearchId, listingId], map: "saved_search_alert_logs_unique_idx")
  @@index([savedSearchId, createdAt], map: "saved_search_alert_logs_search_created_idx")
  @@map("saved_search_alert_logs")
}

model Review {
  id         String    @id @db.VarChar(120)
  targetType String    @map("target_type") @db.VarChar(30)
  targetId   String    @map("target_id") @db.VarChar(120)
  authorId   String?   @map("author_id") @db.VarChar(120)
  authorName String    @map("author_name") @db.VarChar(160)
  rating     Int
  body       String    @db.Text
  verified   Boolean   @default(false)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(6)

  complaintsAsSubject  Complaint[]       @relation("ComplaintSubjectReview")
  moderationQueueItems ModerationQueue[] @relation("ModerationQueueReview")

  @@index([targetType, targetId], map: "reviews_target_idx")
  @@map("reviews")
}

model StripeOrder {
  id          String      @id @db.VarChar(120)
  sessionId   String      @unique @map("session_id") @db.VarChar(240)
  userId      String?     @map("user_id") @db.VarChar(120)
  listingId   String?     @map("listing_id") @db.VarChar(120)
  tier        ListingTier
  amountCents Int         @map("amount_cents")
  currency    String      @default("usd") @db.VarChar(10)
  status      String      @default("pending") @db.VarChar(30)
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("stripe_orders")
}

enum SubscriptionTier {
  agent_pro
  super_agent
  agency

  @@map("subscription_tier")
}

enum SubscriptionInterval {
  month
  year

  @@map("subscription_interval")
}

enum SubscriptionStatus {
  active
  trialing
  past_due
  canceled
  unpaid
  incomplete
  incomplete_expired

  @@map("subscription_status")
}

model StripeCustomer {
  id               String   @id @default(cuid()) @db.VarChar(120)
  userId           String   @unique @map("user_id") @db.VarChar(120)
  stripeCustomerId String   @unique @map("stripe_customer_id") @db.VarChar(120)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]

  @@map("stripe_customers")
}

model Subscription {
  id                   String               @id @default(cuid()) @db.VarChar(120)
  userId               String               @map("user_id") @db.VarChar(120)
  stripeCustomerId     String               @map("stripe_customer_id") @db.VarChar(120)
  stripeSubscriptionId String               @unique @map("stripe_subscription_id") @db.VarChar(120)
  tier                 SubscriptionTier
  interval             SubscriptionInterval
  status               SubscriptionStatus
  currentPeriodStart   DateTime             @map("current_period_start") @db.Timestamptz(6)
  currentPeriodEnd     DateTime             @map("current_period_end") @db.Timestamptz(6)
  cancelAtPeriodEnd    Boolean              @default(false) @map("cancel_at_period_end")
  canceledAt           DateTime?            @map("canceled_at") @db.Timestamptz(6)
  endedAt              DateTime?            @map("ended_at") @db.Timestamptz(6)
  trialStart           DateTime?            @map("trial_start") @db.Timestamptz(6)
  trialEnd             DateTime?            @map("trial_end") @db.Timestamptz(6)
  metadata             Json?
  createdAt            DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  stripeCustomer StripeCustomer @relation(fields: [stripeCustomerId], references: [stripeCustomerId], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status], map: "subscriptions_user_status_idx")
  @@index([stripeCustomerId], map: "subscriptions_stripe_customer_idx")
  @@index([status, currentPeriodEnd], map: "subscriptions_status_period_end_idx")
  @@map("subscriptions")
}

model GeorgianPaymentOrder {
  id                String           @id @default(uuid()) @db.Uuid
  provider          String           @db.VarChar(20)
  providerOrderId   String           @map("provider_order_id") @db.VarChar(240)
  providerPaymentId String?          @map("provider_payment_id") @db.VarChar(240)
  userId            String?          @map("user_id") @db.VarChar(120)
  listingId         String?          @map("listing_id") @db.VarChar(120)
  tier              String           @db.VarChar(30)
  amountTetri       Int              @map("amount_tetri")
  currency          String           @default("GEL") @db.VarChar(3)
  status            String           @default("pending") @db.VarChar(30)
  lastEventId       String?          @map("last_event_id") @db.VarChar(240)
  lastEventPayload  Json?            @map("last_event_payload")
  paidAt            DateTime?        @map("paid_at") @db.Timestamptz(6)
  refundedAt        DateTime?        @map("refunded_at") @db.Timestamptz(6)
  disputedAt        DateTime?        @map("disputed_at") @db.Timestamptz(6)
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt         DateTime?        @map("deleted_at") @db.Timestamptz(6)
  auctionDeposits   AuctionDeposit[]

  @@unique([provider, providerOrderId], map: "georgian_payment_orders_provider_order_id_key")
  @@index([provider, providerPaymentId], map: "georgian_payment_orders_provider_provider_payment_id_idx")
  @@index([status, createdAt(sort: Desc)], map: "georgian_payment_orders_status_created_at_idx")
  @@index([listingId], map: "georgian_payment_orders_listing_id_idx")
  @@map("georgian_payment_orders")
}

model VerificationRequest {
  id                String    @id @default(uuid()) @db.Uuid
  subjectType       String    @map("subject_type") @db.VarChar(40)
  subjectId         String    @map("subject_id") @db.VarChar(120)
  verificationType  String    @map("verification_type") @db.VarChar(30)
  status            String    @default("pending") @db.VarChar(30)
  personalId        String?   @map("personal_id") @db.VarChar(11)
  businessNumber    String?   @map("business_number") @db.VarChar(9)
  documentUrls      String[]  @default([]) @map("document_urls")
  providerReference String?   @map("provider_reference") @db.VarChar(240)
  reviewedBy        String?   @map("reviewed_by") @db.VarChar(120)
  reviewedAt        DateTime? @map("reviewed_at") @db.Timestamptz(6)
  rejectionReason   String?   @map("rejection_reason") @db.Text
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz(6)

  auditLogs VerificationAuditLog[]

  @@index([status, createdAt(sort: Desc)], map: "verification_requests_status_created_at_idx")
  @@index([subjectType, subjectId], map: "verification_requests_subject_idx")
  @@map("verification_requests")
}

model VerificationAuditLog {
  id                    String              @id @default(uuid()) @db.Uuid
  verificationRequestId String              @map("verification_request_id") @db.Uuid
  actorId               String?             @map("actor_id") @db.VarChar(120)
  fromStatus            String?             @map("from_status") @db.VarChar(30)
  toStatus              String              @map("to_status") @db.VarChar(30)
  note                  String?             @db.Text
  createdAt             DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  request               VerificationRequest @relation(fields: [verificationRequestId], references: [id], onDelete: Cascade)

  @@index([verificationRequestId], map: "verification_audit_logs_request_id_idx")
  @@map("verification_audit_logs")
}

model RecommendationAudit {
  id               String    @id @default(uuid()) @db.Uuid
  actorUserId      String    @map("actor_user_id") @db.VarChar(120)
  recommendationId String    @map("recommendation_id") @db.VarChar(80)
  scope            Json      @default("{}")
  updatedListings  Int       @default(0) @map("updated_listings")
  message          String    @db.Text
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@index([createdAt(sort: Desc)], map: "recommendation_audit_created_at_idx")
  @@index([recommendationId], map: "recommendation_audit_recommendation_id_idx")
  @@map("recommendation_audit")
}

/// Append-only admin control-plane audit (CMS, flags, etc.). Prefer soft-delete only for compliance redaction.
model AdminAuditLog {
  id         String    @id @default(uuid()) @db.Uuid
  actorId    String    @map("actor_id") @db.VarChar(120)
  actorName  String    @map("actor_name") @db.VarChar(200)
  actorRole  String    @map("actor_role") @db.VarChar(40)
  action     String    @db.VarChar(160)
  targetType String    @map("target_type") @db.VarChar(80)
  targetId   String    @map("target_id") @db.VarChar(200)
  details    Json      @default("{}")
  ipAddress  String?   @map("ip_address") @db.VarChar(120)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@index([createdAt(sort: Desc)], map: "admin_audit_logs_created_at_idx")
  @@index([targetType, targetId], map: "admin_audit_logs_target_idx")
  @@index([actorId, createdAt(sort: Desc)], map: "admin_audit_logs_actor_created_idx")
  @@map("admin_audit_logs")
}

/// External feed partners (aggregators, portals, CRMs). Do not store secrets in `authConfig` — use env/KMS; this field is non-secret metadata only.
model Partner {
  id                 String   @id @default(uuid()) @db.Uuid
  slug               String   @unique @db.VarChar(120)
  name               String   @db.VarChar(200)
  kind               String   @db.VarChar(40)
  baseUrl            String?  @map("base_url") @db.Text
  feedUrlTemplate    String?  @map("feed_url_template") @db.Text
  feedFormat         String   @map("feed_format") @db.VarChar(16)
  importsFrom        Boolean  @default(false) @map("imports_from")
  exportsTo          Boolean  @default(false) @map("exports_to")
  authKind           String?  @map("auth_kind") @db.VarChar(24)
  authConfig         Json?    @map("auth_config")
  rateLimitPerMinute Int      @default(60) @map("rate_limit_per_minute")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  mappings         PartnerMapping[]
  importJobs       ImportJob[]
  exportJobs       ExportJob[]
  categoryMappings PartnerCategoryMapping[]
  syndicationRules SyndicationRule[]

  @@map("partners")
}

model PartnerMapping {
  id           String    @id @default(uuid()) @db.Uuid
  partnerId    String    @map("partner_id") @db.Uuid
  listingId    String    @map("listing_id") @db.VarChar(120)
  externalId   String?   @map("external_id") @db.Text
  externalUrl  String?   @map("external_url") @db.Text
  status       String    @default("pending") @db.VarChar(20)
  lastSyncedAt DateTime? @map("last_synced_at") @db.Timestamptz(6)
  lastError    String?   @map("last_error") @db.Text
  syncAttempts Int       @default(0) @map("sync_attempts")
  metadata     Json      @default("{}")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([partnerId, listingId], map: "partner_mappings_partner_listing_key")
  @@index([partnerId, status], map: "partner_mappings_partner_idx")
  @@index([listingId], map: "partner_mappings_listing_idx")
  @@map("partner_mappings")
}

model ImportJob {
  id                 String    @id @default(uuid()) @db.Uuid
  partnerId          String    @map("partner_id") @db.Uuid
  agencyProfileId    String?   @map("agency_profile_id") @db.VarChar(120)
  developerProfileId String?   @map("developer_profile_id") @db.VarChar(120)
  feedUrl            String?   @map("feed_url") @db.Text
  feedContentHash    String?   @map("feed_content_hash") @db.VarChar(128)
  recordsReceived    Int       @default(0) @map("records_received")
  recordsCreated     Int       @default(0) @map("records_created")
  recordsUpdated     Int       @default(0) @map("records_updated")
  recordsSkipped     Int       @default(0) @map("records_skipped")
  recordsErrored     Int       @default(0) @map("records_errored")
  status             String    @default("queued") @db.VarChar(20)
  startedAt          DateTime? @map("started_at") @db.Timestamptz(6)
  completedAt        DateTime? @map("completed_at") @db.Timestamptz(6)
  errorSummary       String?   @map("error_summary") @db.Text
  logUrl             String?   @map("log_url") @db.Text
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  partner          Partner           @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  agencyProfile    AgencyProfile?    @relation(fields: [agencyProfileId], references: [id], onDelete: SetNull)
  developerProfile DeveloperProfile? @relation(fields: [developerProfileId], references: [id], onDelete: SetNull)
  stagingRows      ImportStaging[]

  @@index([partnerId, createdAt(sort: Desc)], map: "import_jobs_partner_idx")
  @@index([status, createdAt(sort: Desc)], map: "import_jobs_status_idx")
  @@map("import_jobs")
}

model ExportJob {
  id              String    @id @default(uuid()) @db.Uuid
  partnerId       String    @map("partner_id") @db.Uuid
  format          String    @db.VarChar(16)
  filter          Json?
  recordsCount    Int       @default(0) @map("records_count")
  outputUrl       String?   @map("output_url") @db.Text
  outputSizeBytes BigInt?   @map("output_size_bytes")
  outputSha256    String?   @map("output_sha256") @db.VarChar(64)
  status          String    @default("queued") @db.VarChar(20)
  startedAt       DateTime? @map("started_at") @db.Timestamptz(6)
  completedAt     DateTime? @map("completed_at") @db.Timestamptz(6)
  errorSummary    String?   @map("error_summary") @db.Text
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId, createdAt(sort: Desc)], map: "export_jobs_partner_idx")
  @@index([status, createdAt(sort: Desc)], map: "export_jobs_status_idx")
  @@map("export_jobs")
}

model ImportStaging {
  id               String    @id @default(uuid()) @db.Uuid
  importJobId      String    @map("import_job_id") @db.Uuid
  externalId       String    @map("external_id") @db.VarChar(512)
  rawPayload       Json      @map("raw_payload")
  matchedListingId String?   @map("matched_listing_id") @db.VarChar(120)
  matchConfidence  Decimal?  @map("match_confidence") @db.Decimal(4, 3)
  matchMethod      String?   @map("match_method") @db.VarChar(32)
  status           String    @default("pending") @db.VarChar(20)
  errorMessage     String?   @map("error_message") @db.Text
  processedAt      DateTime? @map("processed_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  importJob      ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)
  matchedListing Listing?  @relation("ImportStagingMatchedListing", fields: [matchedListingId], references: [id], onDelete: SetNull)

  @@index([importJobId, status], map: "import_staging_job_idx")
  @@index([externalId], map: "import_staging_external_idx")
  @@map("import_staging")
}

model PartnerCategoryMapping {
  partnerId    String              @map("partner_id") @db.Uuid
  partnerValue String              @map("partner_value") @db.VarChar(240)
  ourCategory  ListingPropertyType @map("our_category")
  ourDealType  ListingDealType     @map("our_deal_type")

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@id([partnerId, partnerValue])
  @@map("partner_category_mappings")
}

/// Empty filter arrays mean “no restriction” in application logic.
model SyndicationRule {
  id                  String                @id @default(uuid()) @db.Uuid
  partnerId           String                @map("partner_id") @db.Uuid
  appliesCategories   ListingPropertyType[] @default([]) @map("applies_categories")
  appliesDealTypes    ListingDealType[]     @default([]) @map("applies_deal_types")
  appliesCityNames    String[]              @default([]) @map("applies_city_names")
  minPromotionTier    ListingTier?          @map("min_promotion_tier")
  excludeOwnerKinds   String[]              @default([]) @map("exclude_owner_kinds")
  maskPhone           Boolean               @default(true) @map("mask_phone")
  maskAddress         Boolean               @default(false) @map("mask_address")
  hideCadastre        Boolean               @default(true) @map("hide_cadastre")
  agencyPays          Boolean               @default(false) @map("agency_pays")
  costPerListingTetri Int                   @default(0) @map("cost_per_listing_tetri")
  isActive            Boolean               @default(true) @map("is_active")
  createdAt           DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime              @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId], map: "syndication_rules_partner_idx")
  @@map("syndication_rules")
}

model Complaint {
  id                        String              @id @default(uuid()) @db.Uuid
  shortId                   String              @unique @default(cuid()) @map("short_id") @db.VarChar(32)
  subjectKind               String              @map("subject_kind") @db.VarChar(24)
  subjectId                 String              @map("subject_id") @db.VarChar(120)
  subjectListingId          String?             @map("subject_listing_id") @db.VarChar(120)
  subjectUserId             String?             @map("subject_user_id") @db.VarChar(120)
  subjectReviewId           String?             @map("subject_review_id") @db.VarChar(120)
  subjectAgencyProfileId    String?             @map("subject_agency_profile_id") @db.VarChar(120)
  subjectDeveloperProfileId String?             @map("subject_developer_profile_id") @db.VarChar(120)
  subjectProjectDirectoryId String?             @map("subject_project_directory_id") @db.VarChar(120)
  subjectMessageId          String?             @map("subject_message_id") @db.VarChar(120)
  reporterId                String?             @map("reporter_id") @db.VarChar(120)
  reporterEmail             String?             @map("reporter_email") @db.VarChar(240)
  reporterSessionId         String?             @map("reporter_session_id") @db.Uuid
  reporterIp                String?             @map("reporter_ip") @db.VarChar(64)
  kind                      ComplaintKind
  description               String?             @db.Text
  evidenceUrls              String[]            @default([]) @map("evidence_urls")
  status                    ComplaintStatus     @default(open)
  priority                  ComplaintPriority   @default(normal)
  assignedToId              String?             @map("assigned_to") @db.VarChar(120)
  assignedAt                DateTime?           @map("assigned_at") @db.Timestamptz(6)
  resolvedAt                DateTime?           @map("resolved_at") @db.Timestamptz(6)
  resolvedById              String?             @map("resolved_by") @db.VarChar(120)
  resolution                String?             @db.Text
  resolutionAction          ModerationDecision? @map("resolution_action")
  duplicateOfId             String?             @map("duplicate_of") @db.Uuid
  createdAt                 DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  subjectListing          Listing?           @relation("ComplaintSubjectListing", fields: [subjectListingId], references: [id], onDelete: Cascade)
  subjectUserProfile      User?              @relation("ComplaintReportedUser", fields: [subjectUserId], references: [id], onDelete: Cascade)
  subjectReview           Review?            @relation("ComplaintSubjectReview", fields: [subjectReviewId], references: [id], onDelete: Cascade)
  subjectAgencyProfile    AgencyProfile?     @relation("ComplaintSubjectAgency", fields: [subjectAgencyProfileId], references: [id], onDelete: Cascade)
  subjectDeveloperProfile DeveloperProfile?  @relation("ComplaintSubjectDeveloper", fields: [subjectDeveloperProfileId], references: [id], onDelete: Cascade)
  subjectProjectDirectory ProjectDirectory?  @relation("ComplaintSubjectProject", fields: [subjectProjectDirectoryId], references: [id], onDelete: Cascade)
  reporter                User?              @relation("ComplaintReporter", fields: [reporterId], references: [id], onDelete: SetNull)
  assignedTo              User?              @relation("ComplaintAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  resolvedBy              User?              @relation("ComplaintResolver", fields: [resolvedById], references: [id], onDelete: SetNull)
  duplicateOf             Complaint?         @relation("ComplaintDuplicateOf", fields: [duplicateOfId], references: [id], onDelete: SetNull)
  duplicates              Complaint[]        @relation("ComplaintDuplicateOf")
  linkedModerationActions ModerationAction[] @relation("ModerationActionComplaint")

  @@index([status, priority(sort: Desc), createdAt], map: "complaints_status_priority_created_at_idx")
  @@index([subjectListingId], map: "complaints_subject_listing_id_idx")
  @@index([subjectUserId], map: "complaints_subject_user_id_idx")
  @@index([assignedToId, status], map: "complaints_assigned_to_status_idx")
  @@index([kind, createdAt(sort: Desc)], map: "complaints_kind_created_at_idx")
  @@map("complaints")
}

model ModerationQueue {
  id               String                @id @default(uuid()) @db.Uuid
  subjectKind      String                @map("subject_kind") @db.VarChar(24)
  subjectId        String                @map("subject_id") @db.VarChar(120)
  subjectListingId String?               @map("subject_listing_id") @db.VarChar(120)
  subjectReviewId  String?               @map("subject_review_id") @db.VarChar(120)
  subjectUserId    String?               @map("subject_user_id") @db.VarChar(120)
  subjectMediaId   String?               @map("subject_media_id") @db.Uuid
  reason           String                @db.Text
  fraudScore       Decimal?              @map("fraud_score") @db.Decimal(4, 2)
  signals          Json?
  priority         ComplaintPriority     @default(normal)
  status           ModerationQueueStatus @default(pending)
  assignedToId     String?               @map("assigned_to") @db.VarChar(120)
  assignedAt       DateTime?             @map("assigned_at") @db.Timestamptz(6)
  reviewedAt       DateTime?             @map("reviewed_at") @db.Timestamptz(6)
  reviewedById     String?               @map("reviewed_by") @db.VarChar(120)
  decision         ModerationDecision?
  decisionNotes    String?               @map("decision_notes") @db.Text
  createdAt        DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime              @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  subjectListing          Listing?           @relation("ModerationQueueListing", fields: [subjectListingId], references: [id], onDelete: Cascade)
  subjectReview           Review?            @relation("ModerationQueueReview", fields: [subjectReviewId], references: [id], onDelete: Cascade)
  subjectUser             User?              @relation("ModerationQueueSubjectUser", fields: [subjectUserId], references: [id], onDelete: Cascade)
  subjectMedia            ListingMedia?      @relation("ModerationQueueMedia", fields: [subjectMediaId], references: [id], onDelete: Cascade)
  assignedTo              User?              @relation("ModerationQueueAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  reviewedBy              User?              @relation("ModerationQueueReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  linkedModerationActions ModerationAction[] @relation("ModerationActionQueue")

  @@index([status, priority(sort: Desc), createdAt], map: "moderation_queue_status_priority_created_at_idx")
  @@index([assignedToId, status], map: "moderation_queue_assigned_to_status_idx")
  @@index([subjectListingId], map: "moderation_queue_subject_listing_id_idx")
  @@index([priority(sort: Desc), createdAt(sort: Desc)], map: "moderation_queue_priority_created_at_idx")
  @@map("moderation_queue")
}

