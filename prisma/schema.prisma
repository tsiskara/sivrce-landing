  amenities         String[] @default([])
  amenitiesKa       String[] @default([]) @map("amenities_ka")
  bestFor           String[] @default([]) @map("best_for")
  bestForKa         String[] @default([]) @map("best_for_ka")
  investmentNote    String   @map("investment_note") @db.Text
  investmentNoteKa  String   @map("investment_note_ka") @db.Text
  lat               Float    @default(0)
  lng               Float    @default(0)
  image             String   @db.Text
  imageAttribution  String?  @map("image_attribution") @db.Text
  listingsCount     Int      @default(0) @map("listings_count")
  trend             String   @default("stable") @db.VarChar(12)
  trendPercent      String   @default("0%") @map("trend_percent") @db.VarChar(12)
  isActive          Boolean  @default(true) @map("is_active")
  featured          Boolean  @default(false)
  order             Int      @default(0)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  city City @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@index([cityId, isActive, order], map: "neighborhoods_city_active_order_idx")
  @@index([slug, isActive], map: "neighborhoods_slug_active_idx")
  @@index([featured, order], map: "neighborhoods_featured_order_idx")
  @@map("neighborhoods")
}

// ═══════════════════════════════════════════════════════════════
// SIVRCE REAL-TIME COMMUNICATION ENGINE — Chat + Tour Booking
// 2026 Standard: SSE-based messaging, Redis pub/sub ready
// ═══════════════════════════════════════════════════════════════

enum ChatMessageKind {
  text
  image
  file
  system

  @@map("chat_message_kind")
}

model ChatRoom {
  id          String   @id @default(cuid()) @db.VarChar(120)
  listingId   String?  @map("listing_id") @db.VarChar(120)
  title       String   @db.VarChar(240)
  status      String   @default("active") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  listing      Listing?          @relation(fields: [listingId], references: [id], onDelete: SetNull)
  participants ChatParticipant[]
  messages     ChatMessage[]

  @@index([listingId, status], map: "chat_rooms_listing_status_idx")
  @@index([status, updatedAt(sort: Desc)], map: "chat_rooms_status_updated_idx")
  @@map("chat_rooms")
}

model ChatParticipant {
  id         String    @id @default(cuid()) @db.VarChar(120)
  roomId     String    @map("room_id") @db.VarChar(120)
  userId     String    @map("user_id") @db.VarChar(120)
  role       String    @default("member") @db.VarChar(20)
  joinedAt   DateTime  @default(now()) @map("joined_at") @db.Timestamptz(6)
  lastReadAt DateTime? @map("last_read_at") @db.Timestamptz(6)

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId], map: "chat_participants_room_user_key")
  @@index([userId, joinedAt(sort: Desc)], map: "chat_participants_user_joined_idx")
  @@map("chat_participants")
}

model ChatMessage {
  id        String          @id @default(cuid()) @db.VarChar(120)
  roomId    String          @map("room_id") @db.VarChar(120)
  senderId  String          @map("sender_id") @db.VarChar(120)
  content   String          @db.Text
  kind      ChatMessageKind @default(text)
  metadata  Json            @default("{}")
  createdAt DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt(sort: Desc)], map: "chat_messages_room_created_idx")
  @@index([senderId, createdAt(sort: Desc)], map: "chat_messages_sender_created_idx")
  @@map("chat_messages")
}

enum TourStatus {
  pending
  confirmed
  cancelled_by_guest
  cancelled_by_agent
  completed
  no_show

  @@map("tour_status")
}

model PropertyTour {
  id           String     @id @default(cuid()) @db.VarChar(120)
  listingId    String     @map("listing_id") @db.VarChar(120)
  guestId      String     @map("guest_id") @db.VarChar(120)
  userId       String?    @map("user_id") @db.VarChar(120)
  agentId      String     @map("agent_id") @db.VarChar(120)
  tourDate     DateTime   @map("tour_date") @db.Date
  tourTime     String     @map("tour_time") @db.VarChar(10)
  status       TourStatus @default(pending)
  guestName    String     @map("guest_name") @db.VarChar(160)
  guestPhone   String     @map("guest_phone") @db.VarChar(30)
  guestEmail   String?    @map("guest_email") @db.VarChar(240)
  guestNotes   String?    @map("guest_notes") @db.Text
  agentNotes   String?    @map("agent_notes") @db.Text
  confirmedAt  DateTime?  @map("confirmed_at") @db.Timestamptz(6)
  cancelledAt  DateTime?  @map("cancelled_at") @db.Timestamptz(6)
  cancelReason String?    @map("cancel_reason") @db.VarChar(200)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  listing Listing      @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user    User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  agent   AgentProfile @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([listingId, tourDate], map: "property_tours_listing_date_idx")
  @@index([agentId, tourDate, status], map: "property_tours_agent_date_status_idx")
  @@index([guestId, createdAt(sort: Desc)], map: "property_tours_guest_idx")
  @@index([userId, createdAt(sort: Desc)], map: "property_tours_user_idx")
  @@index([status, tourDate], map: "property_tours_status_date_idx")
  @@map("property_tours")
}

model TourAvailability {
  id           String   @id @default(cuid()) @db.VarChar(120)
  agentId      String   @map("agent_id") @db.VarChar(120)
  dayOfWeek    Int      @map("day_of_week")
  startTime    String   @map("start_time") @db.VarChar(10)
  endTime      String   @map("end_time") @db.VarChar(10)
  slotDuration Int      @default(30) @map("slot_duration")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  agent AgentProfile @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, dayOfWeek, startTime, endTime], map: "tour_availability_agent_day_time_key")
  @@index([agentId, dayOfWeek, isActive], map: "tour_availability_agent_day_active_idx")
  @@map("tour_availabilities")
}

model TourDateOverride {
  id        String    @id @default(cuid()) @db.VarChar(120)
  agentId   String    @map("agent_id") @db.VarChar(120)
  date      DateTime  @db.Date
  isBlocked Boolean   @default(true) @map("is_blocked")
  reason    String?   @db.VarChar(200)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  agent AgentProfile @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, date], map: "tour_date_override_agent_date_key")
  @@index([agentId, date], map: "tour_date_override_agent_date_idx")
  @@map("tour_date_overrides")
}

enum BehaviorKind {
  view
  save
  inquiry
  search
  tour_booking
  share

  @@map("behavior_kind")
}

model UserBehavior {
  id          String       @id @default(cuid()) @db.VarChar(120)
  userId      String       @map("user_id") @db.VarChar(120)
  listingId   String?      @map("listing_id") @db.VarChar(120)
  kind        BehaviorKind
  weight      Float        @default(1.0)
  searchParams Json?       @map("search_params")
  sessionId   String?      @map("session_id") @db.VarChar(120)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing? @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([userId, kind, createdAt(sort: Desc)], map: "user_behaviors_user_kind_created_idx")
  @@index([userId, createdAt(sort: Desc)], map: "user_behaviors_user_created_idx")
  @@index([listingId, kind, createdAt(sort: Desc)], map: "user_behaviors_listing_kind_created_idx")
  @@index([sessionId, createdAt(sort: Desc)], map: "user_behaviors_session_created_idx")
  @@map("user_behaviors")
}

model ListingEmbedding {
  id          String   @id @default(cuid()) @db.VarChar(120)
  listingId   String   @unique @map("listing_id") @db.VarChar(120)
  embedding   Unsupported("vector(1536)")
  model       String   @db.VarChar(80)
  contentHash String   @map("content_hash") @db.VarChar(64)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId], map: "listing_embeddings_listing_id_idx")
  @@map("listing_embeddings")
}

model UserEmbedding {
  id            String   @id @default(cuid()) @db.VarChar(120)
  userId        String   @unique @map("user_id") @db.VarChar(120)
  embedding     Unsupported("vector(1536)")
  model         String   @db.VarChar(80)
  behaviorCount Int      @default(0) @map("behavior_count")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "user_embeddings_user_id_idx")
  @@map("user_embeddings")
}

model PushSubscription {
  id        String   @id @default(cuid()) @db.VarChar(120)
  userId    String   @map("user_id") @db.VarChar(120)
  endpoint  String   @db.Text
  p256dh    String   @map("p256dh") @db.VarChar(255)
  auth      String   @db.VarChar(255)
  kind      String   @default("web") @db.VarChar(20)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([userId, endpoint], map: "push_subscriptions_user_endpoint_key")
  @@index([userId, isActive], map: "push_subscriptions_user_active_idx")
  @@index([isActive, updatedAt], map: "push_subscriptions_active_updated_idx")
  @@map("push_subscriptions")
}

model ListingAlertSubscription {
  id             String    @id @default(cuid()) @db.VarChar(120)
  email          String    @map("email") @db.VarChar(320)
  source         String    @default("homepage_cta") @map("source") @db.VarChar(60)
  confirmedAt    DateTime? @map("confirmed_at") @db.Timestamptz(6)
  unsubscribedAt DateTime? @map("unsubscribed_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([email, createdAt], map: "listing_alert_subs_email_created_idx")
  @@index([createdAt], map: "listing_alert_subs_created_idx")
  @@map("listing_alert_subscriptions")
}
