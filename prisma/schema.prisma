generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- NextAuth / Auth.js (composite keys aligned with @auth/prisma-adapter expectations)

model User {
  id            String    @id @default(cuid()) @db.VarChar(120)
  name          String?   @db.VarChar(160)
  email         String    @unique @db.VarChar(240)
  emailVerified DateTime? @map("email_verified") @db.Timestamptz(6)
  phone         String?   @db.VarChar(30)
  phoneVerifiedAt DateTime? @map("phone_verified_at") @db.Timestamptz(6)
  image         String?   @db.Text
  role          UserRole  @default(buyer)
  trustScore    Int       @default(70) @map("trust_score")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  accounts             Account[]
  sessions             Session[]
  authenticators       Authenticator[]
  savedListings        SavedListing[]
  uploadedListingMedia ListingMedia[]   @relation("ListingMediaUploader")
  auctionsOrganized    Auction[]        @relation("AuctionOrganizer")
  auctionsWon          Auction[]        @relation("AuctionWinner")
  auctionDeposits      AuctionDeposit[]
  bids                 Bid[]
  auctionWatchers      AuctionWatcher[]

  complaintsReported        Complaint[]             @relation("ComplaintReporter")
  complaintsAssigned        Complaint[]             @relation("ComplaintAssignee")
  complaintsResolved        Complaint[]             @relation("ComplaintResolver")
  complaintsAgainstProfile  Complaint[]             @relation("ComplaintReportedUser")
  moderationQueuesAssigned  ModerationQueue[]       @relation("ModerationQueueAssignee")
  moderationQueuesReviewed  ModerationQueue[]       @relation("ModerationQueueReviewer")
  moderationQueuesAsSubject ModerationQueue[]       @relation("ModerationQueueSubjectUser")
  moderationActionLogs      ModerationAction[]      @relation("ModerationActionModerator")
  fraudSignalsResolved      FraudSignal[]           @relation("FraudSignalResolver")
  shadowBans                ShadowBan[]             @relation("ShadowBanSubject")
  shadowBansIssued          ShadowBan[]             @relation("ShadowBanIssuer")
  shadowBansLifted          ShadowBan[]             @relation("ShadowBanLifter")
  blocklistPhonesCreated    BlocklistPhone[]        @relation("BlocklistPhoneCreator")
  blocklistEmailsCreated    BlocklistEmail[]        @relation("BlocklistEmailCreator")
  blocklistIpsCreated       BlocklistIp[]           @relation("BlocklistIpCreator")
  blocklistDevicesCreated   BlocklistDevice[]       @relation("BlocklistDeviceCreator")
  suspiciousActivityLogs    SuspiciousActivityLog[] @relation("SuspiciousActivityUser")
  systemConfigsUpdated      SystemConfig[]          @relation("SystemConfigUpdater")
  building3DsUpdated        Building3D[]            @relation("Building3DUpdater")
  stripeCustomer            StripeCustomer?
  subscriptions             Subscription[]
  blogPosts                 BlogPost[]
  behaviors                 UserBehavior[]
  embedding                 UserEmbedding?
  propertyTours             PropertyTour[]

  @@map("users")
}

model Account {
  userId            String  @map("user_id") @db.VarChar(120)
  type              String  @db.VarChar(40)
  provider          String  @db.VarChar(60)
  providerAccountId String  @map("provider_account_id") @db.VarChar(240)
  refresh_token     String? @map("refresh_token") @db.Text
  access_token      String? @map("access_token") @db.Text
  expires_at        Int?    @map("expires_at")
  token_type        String? @map("token_type") @db.VarChar(40)
  scope             String? @db.Text
  id_token          String? @map("id_token") @db.Text
  session_state     String? @map("session_state") @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId], map: "accounts_user_id_idx")
  @@map("accounts")
}

model Session {
  sessionToken String   @id @map("session_token") @db.VarChar(240)
  userId       String   @map("user_id") @db.VarChar(120)
  expires      DateTime @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "sessions_user_id_idx")
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime @db.Timestamptz(6)

  @@id([identifier, token])
  @@map("verification_tokens")
}

model Authenticator {
  credentialID         String  @unique @map("credential_id")
  userId               String  @map("user_id") @db.VarChar(120)
  providerAccountId    String  @map("provider_account_id")
  credentialPublicKey  String  @map("credential_public_key")
  counter              Int
  credentialDeviceType String  @map("credential_device_type")
  credentialBackedUp   Boolean @map("credential_backed_up")
  transports           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
  @@map("authenticators")
}

enum UserRole {
  buyer
  seller
  agent
  agency
  developer
  admin

  @@map("user_role")
}

enum ListingDealType {
  buy
  rent
  daily
  mortgage

  @@map("listing_deal_type")
}

enum ListingPropertyType {
  apartment
  house
  villa
  commercial
  land
  hotel
  party_house

  @@map("listing_property_type")
}

enum ListingTier {
  standard
  vip
  super_vip @map("super-vip")
  diamond

  @@map("listing_tier")
}

enum ListingCurrency {
  USD
  GEL

  @@map("listing_currency")
}

enum ListingStatus {
  active
  sold
  pending
  expired
  withdrawn

  @@map("listing_status")
}

enum MediaKind {
  photo
  video
  panorama
  floor_plan

  @@map("media_kind")
}

enum MediaProcessingStatus {
  queued
  processing
  ready
  failed

  @@map("media_processing_status")
}

enum PoiKind {
  metro
  bus_stop
  minibus_stop
  cable_car
  funicular
  school
  kindergarten
  pharmacy
  supermarket
  park
  hospital
  cafe
  other

  @@map("poi_kind")
}

model Poi {
  id        String                                @id @default(uuid()) @db.Uuid
  kind      PoiKind
  nameKa    String                                @map("name_ka") @db.VarChar(240)
  nameEn    String?                               @map("name_en") @db.VarChar(240)
  nameRu    String?                               @map("name_ru") @db.VarChar(240)
  location  Unsupported("geography(Point, 4326)")
  isActive  Boolean                               @default(true) @map("is_active")
  metadata  Json?
  createdAt DateTime                              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime                              @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  listingNearestLinks ListingNearestPoi[]

  @@map("pois")
}

model ListingNearestPoi {
  id           BigInt   @id @default(autoincrement())
  listingId    String   @map("listing_id") @db.VarChar(120)
  poiId        String   @map("poi_id") @db.Uuid
  poiKind      PoiKind  @map("poi_kind")
  distanceM    Int      @map("distance_m")
  walkTimeMin  Int?     @map("walk_time_min")
  driveTimeMin Int?     @map("drive_time_min")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  poi     Poi     @relation(fields: [poiId], references: [id], onDelete: Cascade)

  @@unique([listingId, poiId], map: "listing_nearest_poi_listing_poi_key")
  @@map("listing_nearest_poi")
}

// ── Map AI Zones ──────────────────────────────────────────────────────────

model MapAiZone {
  id                  String   @id @default(cuid()) @db.VarChar(120)
  name                String   @db.VarChar(200)
  district            String   @db.VarChar(120)
  city                String   @db.VarChar(120) @default("Tbilisi")
  polygon             Unsupported("geometry(Polygon, 4326)")
  investmentScore     Int      @default(0) @map("investment_score")
  rentalDemandScore   Int      @default(0) @map("rental_demand_score")
  appreciationForecast Int     @default(0) @map("appreciation_forecast")
  riskScore           Int      @default(0) @map("risk_score")
  livabilityScore     Int      @default(0) @map("livability_score")
  listingCount        Int      @default(0) @map("listing_count")
  avgPricePerSqm      Int      @default(0) @map("avg_price_per_sqm")
  confidence          Int      @default(0)
  reasonCodes         String?  @db.Text @map("reason_codes")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([district])
  @@index([investmentScore])
  @@map("map_ai_zones")
}

model ListingMedia {
  id                 String                @id @default(uuid()) @db.Uuid
  listingId          String                @map("listing_id") @db.VarChar(120)
  kind               MediaKind             @default(photo)
  storageBucket      String                @default("listing-media") @map("storage_bucket") @db.VarChar(80)
  storagePath        String                @map("storage_path") @db.Text
  cdnUrl             String?               @map("cdn_url") @db.Text
  width              Int?
  height             Int?
  sizeBytes          BigInt?               @map("size_bytes")
  mimeType           String?               @map("mime_type") @db.VarChar(180)
  fileSha256         String?               @map("file_sha256") @db.VarChar(64)
  position           Int                   @default(0) @db.SmallInt
  isCover            Boolean               @default(false) @map("is_cover")
  captionKa          String?               @map("caption_ka") @db.Text
  captionEn          String?               @map("caption_en") @db.Text
  captionRu          String?               @map("caption_ru") @db.Text
  aiRoomTag          String?               @map("ai_room_tag") @db.VarChar(64)
  aiFeaturesDetected String[]              @default([]) @map("ai_features_detected")
  processingStatus   MediaProcessingStatus @default(ready) @map("processing_status")
  processingError    String?               @map("processing_error") @db.Text
  processedAt        DateTime?             @map("processed_at") @db.Timestamptz(6)
  uploadedBy         String?               @map("uploaded_by") @db.VarChar(120)
  createdAt          DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime              @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt          DateTime?             @map("deleted_at") @db.Timestamptz(6)

  listing              Listing           @relation(fields: [listingId], references: [id], onDelete: Cascade)
  uploader             User?             @relation("ListingMediaUploader", fields: [uploadedBy], references: [id], onDelete: SetNull)
  moderationQueueItems ModerationQueue[] @relation("ModerationQueueMedia")

  @@index([listingId, position], map: "listing_media_listing_position_idx")
  @@index([listingId, kind], map: "listing_media_listing_kind_idx")
  @@index([fileSha256], map: "listing_media_sha256_idx")
  @@index([processingStatus, createdAt], map: "listing_media_processing_idx")
  @@map("listing_media")
}

enum ListingPriceEventType {
  listed
  price_drop
  price_increase
  sold

  @@map("listing_price_event_type")
}

model ListingPriceEvent {
  id            BigInt                @id @default(autoincrement())
  listingId     String                @map("listing_id") @db.VarChar(120)
  eventType     ListingPriceEventType @default(listed)
  price         Int
  previousPrice Int?                  @map("previous_price")
  currency      ListingCurrency
  pricePerSqm   Int?                  @map("price_per_sqm")
  recordedAt    DateTime              @default(now()) @map("recorded_at") @db.Timestamptz(6)

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, recordedAt(sort: Desc)], map: "listing_price_events_listing_recorded_idx")
  @@index([listingId, eventType, recordedAt(sort: Desc)], map: "listing_price_events_listing_type_recorded_idx")
  @@map("listing_price_events")
}

model MarketSnapshot {
  id                  BigInt   @id @default(autoincrement())
  city                String   @db.VarChar(100)
  district            String?  @db.VarChar(120)
  periodMonth         String   @map("period_month") @db.VarChar(7)
  avgPricePerSqm      Int      @map("avg_price_per_sqm")
  medianPrice         Int?
  soldCount           Int      @default(0) @map("sold_count")
  avgDaysOnMarket     Int      @default(0) @map("avg_days_on_market")
  newListingsCount    Int      @default(0) @map("new_listings_count")
  activeListingsCount Int      @default(0) @map("active_listings_count")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([city, district, periodMonth], map: "market_snapshot_city_district_period_key")
  @@index([city, periodMonth], map: "market_snapshot_city_period_idx")
  @@index([district, periodMonth], map: "market_snapshot_district_period_idx")
  @@map("market_snapshots")
}

enum AuctionStatus {
  scheduled
  live
  paused
  ended_sold
  ended_unsold
  cancelled

  @@map("auction_status")
}

enum BidStatus {
  leading
  outbid
  cancelled
  won

  @@map("bid_status")
}

enum AuctionDepositStatus {
  pending
  held
  refunded
  forfeit
  applied

  @@map("auction_deposit_status")
}

enum ComplaintKind {
  spam
  fraud
  harassment
  misinformation
  duplicate_listing
  impersonation
  scam_payment
  illegal_content
  other

  @@map("complaint_kind")
}

enum ComplaintStatus {
  open
  under_review
  resolved
  dismissed
  duplicate

  @@map("complaint_status")
}

enum ComplaintPriority {
  low
  normal
  high
  urgent

  @@map("complaint_priority")
}

enum ModerationDecision {
  approve
  reject
  hide
  delete
  warn_user
  suspend_user
  escalate
  no_action

  @@map("moderation_decision")
}

enum ModerationQueueStatus {
  pending
  in_review
  approved
  rejected
  auto_resolved

  @@map("moderation_queue_status")
}

enum ShadowBanScope {
  all
  listings
  messages
  reviews

  @@map("shadow_ban_scope")
}

model Listing {
  id                            String                                 @id @db.VarChar(120)
  ownerId                       String?                                @map("owner_id") @db.VarChar(120)
  slug                          String                                 @unique @db.VarChar(180)
  title                         String                                 @db.VarChar(180)
  description                   String                                 @db.Text
  dealType                      ListingDealType                        @map("deal_type")
  propertyType                  ListingPropertyType                    @map("type")
  tier                          ListingTier                            @default(standard)
  verified                      Boolean                                @default(false)
  price                         Int
  currency                      ListingCurrency                        @default(GEL)
  pricePerSqm                   Int?                                   @map("price_per_sqm")
  rooms                         Int                                    @default(0)
  bedrooms                      Int                                    @default(0)
  bathrooms                     Int                                    @default(0)
  area                          Float
  floor                         Int?
  totalFloors                   Int?                                   @map("total_floors")
  yearBuilt                     Int?                                   @map("year_built")
  city                          String                                 @db.VarChar(100)
  district                      String                                 @db.VarChar(120)
  address                       String                                 @db.VarChar(240)
  lat                           Float
  lng                           Float
  location                      Unsupported("geography(Point, 4326)")?
  searchVector                  Unsupported("tsvector")?               @map("search_vector")
  images                        String[]                               @default([])
  features                      String[]                               @default([])
  extendedFields                Json?                                  @map("extended_fields")
  agent                         Json
  listingPhone                  String?                                @map("listing_phone") @db.VarChar(30)
  listingPhoneVerifiedAt        DateTime?                              @map("listing_phone_verified_at") @db.Timestamptz(6)
  views                         Int                                    @default(0)
  trustScore                    Int                                    @default(70) @map("trust_score")
  fillPercentage                Int                                    @default(0) @map("fill_percentage") @db.SmallInt
  tierExpiresAt                 DateTime?                              @map("tier_expires_at") @db.Timestamptz(6)
  tierPurchasedAt               DateTime?                              @map("tier_purchased_at") @db.Timestamptz(6)
  tierPaymentOrderId            String?                                @map("tier_payment_order_id") @db.VarChar(36)
  status                        ListingStatus                          @default(active)
  soldAt                        DateTime?                              @map("sold_at") @db.Timestamptz(6)
  soldPrice                     Int?                                   @map("sold_price")
  createdAt                     DateTime                               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                     DateTime                               @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt                     DateTime?                              @map("deleted_at") @db.Timestamptz(6)
  savedBy                       SavedListing[]
  boostHistory                  ListingBoostHistory[]
  nearestPois                   ListingNearestPoi[]
  media                         ListingMedia[]
  priceEvents                   ListingPriceEvent[]
  auction                       Auction?
  dailyRentalSettings           DailyRentalSettings?
  dailyRentalBookings           DailyRentalBooking[]
  dailyRentalBlockedDates       DailyRentalBlockedDate[]
  complaintsAsSubject           Complaint[]                            @relation("ComplaintSubjectListing")
  moderationQueueItems          ModerationQueue[]                      @relation("ModerationQueueListing")
  duplicateClusterMemberships   DuplicateClusterMember[]
  duplicateClustersRepresenting DuplicateCluster[]                     @relation("DuplicateClusterRepresentative")
  partnerMappings               PartnerMapping[]
  importStagingMatches          ImportStaging[]                        @relation("ImportStagingMatchedListing")
  listingLocation               ListingLocation?
  chatRooms                     ChatRoom[]
  embedding                     ListingEmbedding?
  behaviors                     UserBehavior[]
  propertyTours                 PropertyTour[]

  @@index([deletedAt], map: "listings_deleted_at_idx")
  @@index([city, district], map: "listings_city_district_idx")
  @@index([dealType], map: "listings_deal_type_idx")
  @@index([tierExpiresAt], map: "listings_tier_expires_at_idx")
  @@index([tierPurchasedAt], map: "listings_tier_purchased_at_idx")
  @@index([dealType, city, district, deletedAt], map: "listings_search_core_idx")
  @@index([propertyType, deletedAt], map: "listings_property_type_idx")
  @@index([price, deletedAt], map: "listings_price_idx")
  @@index([area, deletedAt], map: "listings_area_idx")
  @@index([rooms, deletedAt], map: "listings_rooms_idx")
  @@index([floor, deletedAt], map: "listings_floor_idx")
  @@index([yearBuilt, deletedAt], map: "listings_year_built_idx")
  @@index([createdAt(sort: Desc), deletedAt], map: "listings_created_at_idx")
  @@index([verified, deletedAt], map: "listings_verified_idx")
  @@index([trustScore(sort: Desc), deletedAt], map: "listings_trust_score_idx")
  @@index([status, deletedAt], map: "listings_status_deleted_at_idx")
  @@map("listings")
}

model ListingBoostHistory {
  id              String    @id @default(uuid()) @db.Uuid
  listingId       String    @map("listing_id") @db.VarChar(120)
  userId          String?   @map("user_id") @db.VarChar(120)
  fromTier        String    @default("standard") @map("from_tier") @db.VarChar(30)
  toTier          String    @map("to_tier") @db.VarChar(30)
  amountTetri     Int       @map("amount_tetri")
  currency        String    @default("GEL") @db.VarChar(3)
  provider        String?   @db.VarChar(20)
  providerOrderId String?   @map("provider_order_id") @db.VarChar(240)
  durationDays    Int       @default(30) @map("duration_days")
  startedAt       DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  expiresAt       DateTime  @map("expires_at") @db.Timestamptz(6)
  endedAt         DateTime? @map("ended_at") @db.Timestamptz(6)
  endedReason     String?   @map("ended_reason") @db.VarChar(40)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, createdAt(sort: Desc)], map: "listing_boost_history_listing_id_idx")
  @@index([userId, createdAt(sort: Desc)], map: "listing_boost_history_user_id_idx")
  @@index([expiresAt], map: "listing_boost_history_expires_at_idx")
  @@map("listing_boost_history")
}

model DailyRentalSettings {
  id                String   @id @default(uuid()) @db.Uuid
  listingId         String   @unique @map("listing_id") @db.VarChar(120)
  enabled           Boolean  @default(true)
  minNights         Int      @default(1) @map("min_nights")
  maxNights         Int      @default(30) @map("max_nights")
  instantBook       Boolean  @default(false) @map("instant_book")
  checkInHour       Int      @default(15) @map("check_in_hour")
  checkOutHour      Int      @default(11) @map("check_out_hour")
  cleaningFeeTetri  Int      @default(0) @map("cleaning_fee_tetri")
  securityDepositTetri Int   @default(0) @map("security_deposit_tetri")
  weekendPriceTetri Int?     @map("weekend_price_tetri")
  weeklyDiscountPct Int      @default(0) @map("weekly_discount_pct")
  monthlyDiscountPct Int     @default(0) @map("monthly_discount_pct")
  guestCapacity     Int      @default(2) @map("guest_capacity")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("daily_rental_settings")
}

enum BookingStatus {
  pending
  confirmed
  cancelled_by_guest
  cancelled_by_host
  no_show
  completed

  @@map("booking_status")
}

model DailyRentalBooking {
  id              String        @id @default(uuid()) @db.Uuid
  listingId       String        @map("listing_id") @db.VarChar(120)
  guestId         String        @map("guest_id") @db.VarChar(120)
  checkIn         DateTime      @map("check_in") @db.Timestamptz(6)
  checkOut        DateTime      @map("check_out") @db.Timestamptz(6)
  nights          Int
  guestCount      Int           @map("guest_count")
  nightlyPriceTetri Int         @map("nightly_price_tetri")
  cleaningFeeTetri Int         @map("cleaning_fee_tetri")
  securityDepositTetri Int     @map("security_deposit_tetri")
  discountTetri   Int           @default(0) @map("discount_tetri")
  totalTetri      Int           @map("total_tetri")
  currency        String        @default("GEL") @db.VarChar(3)
  status          BookingStatus @default(pending)
  guestName       String        @map("guest_name") @db.VarChar(160)
  guestPhone      String        @map("guest_phone") @db.VarChar(30)
  guestEmail      String?       @map("guest_email") @db.VarChar(240)
  guestNotes      String?       @map("guest_notes") @db.Text
  hostNotes       String?       @map("host_notes") @db.Text
  paymentOrderId  String?       @map("payment_order_id") @db.VarChar(36)
  paidAt          DateTime?     @map("paid_at") @db.Timestamptz(6)
  cancelledAt     DateTime?     @map("cancelled_at") @db.Timestamptz(6)
  cancelReason    String?       @map("cancel_reason") @db.VarChar(200)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, checkIn, checkOut], map: "daily_rental_booking_listing_dates_idx")
  @@index([guestId, createdAt(sort: Desc)], map: "daily_rental_booking_guest_idx")
  @@index([status, checkIn], map: "daily_rental_booking_status_checkin_idx")
  @@map("daily_rental_bookings")
}

model DailyRentalBlockedDate {
  id        String   @id @default(uuid()) @db.Uuid
  listingId String   @map("listing_id") @db.VarChar(120)
  date      DateTime @db.Date
  reason    String?  @db.VarChar(120)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

